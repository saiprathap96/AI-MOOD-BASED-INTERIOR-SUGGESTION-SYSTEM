# Server Configuration
PORT=5000
NODE_ENV=development

# AI API Keys (At least one is recommended for live AI suggestions)
# If none are provided, the backend runs in a premium "Demo Mock Mode"
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Optional)
# If omitted, a local JSON file database is used at backend/data/suggestions.json
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here
